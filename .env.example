# PowerPulse - PRODUCTION ortam degiskenleri (VPS)
#
# Bu dosyayi ".env" olarak kopyala ve degerleri doldur:
#   cp .env.example .env
#
# ".env" dosyasi ASLA git'e commit edilmemeli (bkz. .gitignore).
#
# Asagida "*** DEGISTIR ***" yazan HER deger, gercek/guvenli bir
# degerle degistirilmeden prod'a cikilmamali - varsayilanlari
# kullanmak, uygulamayi herkesin tahmin edebilecegi bir anahtarla
# internete acmak demektir.

# --- Alan adi (domain) ---
# Caddy, bu adres icin otomatik HTTPS sertifikasi alir. DNS A kaydinin
# VPS'in genel IP adresine isaret ettiginden emin ol.
DOMAIN=api.senin-alan-adin.com   # *** DEGISTIR ***

# --- PostgreSQL ---
POSTGRES_DB=powerpulse_db
POSTGRES_USER=powerpulse_user
POSTGRES_PASSWORD=degistir-bu-sifreyi-guclu-bir-sifreyle   # *** DEGISTIR ***

# --- JWT (giris/oturum) ---
# En az 32 karakter, rastgele/tahmin edilemez bir deger olmali.
# Uretmek icin: openssl rand -base64 48
JWT_SECRET=degistir-bu-cok-uzun-ve-rastgele-bir-deger-olmali   # *** DEGISTIR ***
JWT_EXPIRATION_MS=604800000

# --- Internal senkronizasyon (Sensors -> Core) ---
# Yine rastgele bir deger uret: openssl rand -base64 32
INTERNAL_API_KEY=degistir-bu-da-rastgele-olmali   # *** DEGISTIR ***

# --- Frontend (Vercel) ---
# Vercel'e deploy ettigin projenin gercek adresi - CORS burada
# kullanilir, sadece bu origin'den gelen isteklere izin verilir.
# Birden fazla origin gerekiyorsa virgulle ayir (ör. asil domain +
# bir Vercel preview URL'i).
FRONTEND_URL=https://senin-projen.vercel.app   # *** DEGISTIR ***

# --- Faturalama ---
BASE_RATE_PER_KWH=2.10

# --- Telemetry / Snapshot ayarlari (varsayilanlar genelde yeterli) ---
TELEMETRY_MAX_INTERVAL_SECONDS=10
SNAPSHOT_INTERVAL_MS=900000
SNAPSHOT_INITIAL_DELAY_MS=60000

# --- E-posta bildirimleri (istege bagli, kapaliysa bos birak) ---
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# --- Gemini AI (AI danismani icin) ---
GEMINI_API_KEY=   # *** DEGISTIR *** (Google AI Studio'dan alinir)
GEMINI_MODEL=gemini-3-flash-preview
